{
	"geode": "5.3.0",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},

	"id": "zyyedev.zoomify",
	"name": "Zoomify",
	"version": "1.0.0",
	"developer": "ZyyeDev",
	"description": "Lets you zoom while on the pause menu",

	"links": {
		"source": "https://github.com/ZyyeDev/Zoomify"
	},
	"tags": [
		"enhancement",
		"interface",
		"utility"
	],

	"resources": {
		"sprites": [
			"resources/*.png"
		]
	},
	"dependencies": {
		"geode.node-ids": {
			"version": ">=v1.23.3"
		}
	},

	"settings": {
		"zoom-sensitivity": {
			"name": "Zoom Sensitivity",
			"type": "float",
			"min": 0.1,
			"max": 10,
			"default": 1,
			"control": {
				"slider": true
			},
			"platforms": ["win", "mac"]
		},
		"toggle_menu": {
			"type": "keybind",
			"name": "Toggle Pause Menu",
			"default": "Home",
			"platforms": ["win"]
		}
	}
}
